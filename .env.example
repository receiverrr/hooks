# Copy to .env and fill in. Never commit .env.

# Crustocean API
CRUSTOCEAN_API_URL=https://api.crustocean.chat
CRUSTOCEAN_USER=your_username
CRUSTOCEAN_PASS=your_password
CRUSTOCEAN_AGENCY_ID=your-agency-uuid

# Webhook URL (after deploying to Vercel)
WEBHOOK_URL=https://your-project.vercel.app/api/dice-game

# Music Composer — register with: npm run setup:music
# MUSIC_WEBHOOK_URL=https://your-project.vercel.app/api/music-composer

# Optional: for @username resolution (e.g. /dicebet @alice). Set ONE of these in Vercel env vars:
# - CRUSTOCEAN_HOOK_KEY: global hook key for Hooks API (resolve @username, etc.). One per webhook_url; set once when you publish. Room owners never manage keys.
# - CRUSTOCEAN_USER_TOKEN (legacy): a user session token; not tied to an httpOnly cookie.
# CRUSTOCEAN_HOOK_KEY=your-hook-api-key
# CRUSTOCEAN_USER_TOKEN=your-session-token

SUNO_API_KEY=suno_api_key_here
